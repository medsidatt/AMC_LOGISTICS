/.phpunit.cache
/node_modules

# ------------------------------------------------------------------
# Production deployment
#
# This project is deployed on Infomaniak.
# Production only performs `git pull`.
# It DOES NOT execute npm install or npm run build.
#
# Therefore `public/build` MUST remain version controlled.
# Do NOT ignore or delete it unless the deployment
# process changes to include a build step.
# ------------------------------------------------------------------

/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.env.production
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/.fleet
/.idea
/.vscode

.vercel

*.http
/buckup.php
/command_file.php
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
!/storage/framework/cache/.gitkeep
!/storage/framework/sessions/.gitkeep
!/storage/framework/views/.gitkeep
!/storage/logs/.gitkeep

# Uploaded user files — keep folder structure, ignore contents
/storage/app/*
!/storage/app/.gitkeep
!/storage/app/public
/storage/app/public/*
!/storage/app/public/.gitkeep
