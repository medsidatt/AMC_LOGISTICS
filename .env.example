# =============================================================================
#  AMC Fleet Platform — environment template
#
#  Copy to `.env` and fill in real values. NEVER commit a real `.env`.
#  For production-specific values (APP_DEBUG, LOG_LEVEL, secure cookies, queue
#  worker, scheduler cron) see DEPLOYMENT.md — do not just copy this file to a
#  server unchanged.
# =============================================================================

APP_NAME='AMC Travaux SN'
# local for development, production on servers (see DEPLOYMENT.md).
APP_ENV=local
APP_KEY=
# MUST be false in production — true leaks stack traces and secrets.
APP_DEBUG=true
APP_URL=http://localhost
# Shared secret guarding AJAX-only endpoints — set a long random value.
AJAX_TOKEN=
CRON_TOKEN=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
# debug for local; use warning (or error) in production.
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amc_logistics
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
# Phase 0 runs jobs inline (sync). Switching to `database` requires a running
# queue worker — see DEPLOYMENT.md ("Queue migration — Phase 1").
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Set both to true in production (HTTPS): cookies sent only over TLS, encrypted.
SESSION_SECURE_COOKIE=false
SESSION_ENCRYPT=false

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username@example.com
MAIL_PASSWORD=your-smtp-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_REDIRECT_URI=https://your-domain.example.com/auth/microsoft/callback
# OAuth audience for the sign-in flow. Values:
#   organizations -> any Microsoft Entra ID tenant (work/school accounts)
#   common        -> any tenant + personal Microsoft accounts
#   <tenant-id>   -> restrict to a specific tenant
# SharePoint file access keeps using SHAREPOINT_TENANT_ID regardless.
MICROSOFT_OAUTH_TENANT=organizations
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_LIST_ID=

FLEETI_BASE_URL=https://api.fleeti.co
FLEETI_API_KEY=
FLEETI_BEARER_TOKEN=
MAINTENANCE_WARNING_THRESHOLD_KM=500
ODOMETER_RESET_THRESHOLD_KM=50000
FLEETI_SYNC_INTERVAL_MINUTES=30

# WhatsApp Business Cloud API (Meta) — for driver dispatch notifications.
# Setup gate: AMC Business Manager must be verified, sender phone-number
# registered, and the amc_dispatch_v1 template approved before sends work
# beyond the 5 test recipients.
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_TEMPLATE_DISPATCH=amc_dispatch_v1
WHATSAPP_TEMPLATE_LANG=fr
WHATSAPP_DEFAULT_COUNTRY=MR
